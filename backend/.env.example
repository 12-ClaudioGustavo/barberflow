PORT=3001
CORS_ORIGIN=http://localhost:3000

# PostgreSQL Connection (Supabase Transaction Pooler)
DATABASE_URL=postgresql://postgres.yourprojectid:yourpassword@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Redis Connection (Upstash / Redis Cloud)
REDIS_URL=redis://default:yourpassword@yourredisinstance.upstash.io:6379

# Supabase Auth JWT Secret (Found in Supabase Project Settings -> API)
SUPABASE_JWT_SECRET=your_supabase_jwt_signing_secret
